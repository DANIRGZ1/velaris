{
  "$schema": "https://raw.githubusercontent.com/nicepkg/tauri-v2-schema/main/tauri.conf.schema.json",
  "productName": "Velaris",
  "version": "0.1.0",
  "identifier": "com.velaris.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Velaris",
        "width": 320,
        "height": 370,
        "minWidth": 320,
        "minHeight": 370,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://ddragon.leagueoflegends.com https://raw.communitydragon.org; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost https://ddragon.leagueoflegends.com http://127.0.0.1:2999 https://127.0.0.1:2999 https://127.0.0.1 wss://127.0.0.1 https://lolalytics.com; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "VELARIS_UPDATER_PUBKEY",
      "endpoints": [
        "https://github.com/DANIRGZ1/velaris/releases/latest/download/latest.json"
      ]
    }
  }
}